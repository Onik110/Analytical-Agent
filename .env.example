# 1С COM Connection
COM_SERVER=server_name
COM_PORT=port
COM_BASE=db_name
COM_USER=user
COM_PASSWORD=pass
COM_MAX_ROWS=1000
COM_QUERY_TIMEOUT=30

# Mistral API 
MISTRAL_API_KEY=api_key_mistral
MISTRAL_MODEL=LLM_model_name

# FastAPI Server
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
DEBUG_MODE=True

# Security & Anonymization
ANONYMIZE_FIO=True
ANONYMIZE_TERMINALS=True
ANONYMIZE_VRC=True
ANONYMIZE_REASONS=True
ENABLE_QUERY_VALIDATION=True
MAX_FIX_ATTEMPTS=5
LOG_QUERIES=False

ADMIN_API_KEY=admin_api_key

# Авто-очистка файлов (хранение 30 дней):
FILE_TTL_DAYS=30

DATA_DIR=data
